{
  "name": "sentinel-core-av",
  "version": "1.0.0",
  "description": "Sentinel-Core AV — Advanced USB Antivirus & Endpoint Protection",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node node_modules/electron/cli.js .",
    "dev": "node node_modules/electron/cli.js . --dev",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "author": "Sentinel-Core Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "sql.js": "^1.10.3"
  },
  "build": {
    "appId": "com.sentinel-core.av",
    "productName": "Sentinel-Core AV",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
